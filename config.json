{
  "server": { "addr": ":8080" },
  "logging": { "level": "info", "json": true },
  "cache": { "enabled": true, "ttl": "30s", "max_keys": 10000 },
  "database": {
    "driver": "postgres",
    "dsn": "postgres://costguard:costguard@localhost:5432/costguard?sslmode=disable"
  },
  "budget": {
    "enabled": true,
    "monthly_usd": 0.00000001
  },
  "routing": {
    "default_provider": "openai_primary",
    "fallback_provider": "openai_backup",
    "model_to_provider": {
      "gpt-4o-mini": "openai_primary"
    }
  },
  "providers": {
    "openai": {
      "openai_primary": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      },
      "openai_backup": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      }
    }
  }
}