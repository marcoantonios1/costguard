{
  "server": { "addr": ":8080" },
  "logging": { "level": "debug", "json": false},
  "cache": { "enabled": true, "ttl": "30s", "max_keys": 10000 },
  "database": {
    "driver": "postgres",
    "dsn": "postgres://costguard:costguard@localhost:5432/costguard?sslmode=disable"
  },
  "budget": {
    "enabled": true,
    "monthly_usd": 0.0000825
  },
  "routing": {
    "default_provider": "openai_primary",
    "fallback_provider": "openai_backup",
    "model_to_provider": {
      "gpt-4o-mini": "openai_primary"
    }
  },
  "notify": {
    "email": {
      "enabled": true,
      "host": "smtp.gmail.com",
      "port": 587,
      "username": "alerts@example.com",
      "password": "your-app-password",
      "from": "alerts@example.com",
      "to": [
        "marco@example.com"
      ]
    }
  },
  "providers": {
    "openai": {
      "openai_primary": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      },
      "openai_backup": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      }
    }
  }
}