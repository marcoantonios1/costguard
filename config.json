{
  "server": { "addr": ":8080" },
  "logging": { "level": "debug", "json": false },
  "cache": { "enabled": true, "ttl": "30s", "max_keys": 10000 },
  "database": {
    "driver": "postgres",
    "dsn": "env:COSTGUARD_DATABASE_URL"
  },
  "reports": {
    "monthly_enabled": true,
    "check_interval": "24h",
    "run_on_startup": true
  },
  "budget": {
    "enabled": true,
    "monthly_usd": 100,
    "teams": {
      "backend": 40,
      "mobile": 30
    },
    "projects": {
      "chatbot": 25,
      "analytics": 20
    }
  },
  "routing": {
    "default_provider": "openai_primary",
    "fallback_provider": "openai_backup",
    "model_to_provider": {
      "gpt-4o-mini": "openai_primary"
    }
  },
  "notify": {
    "email": {
      "enabled": true,
      "host": "smtp.gmail.com",
      "port": 587,
      "username": "env:EMAIL_USERNAME",
      "password": "env:EMAIL_PASSWORD",
      "from": "env:EMAIL_FROM",
      "to": ["env:EMAIL_TO"]
    }
  },
  "providers": {
    "openai": {
      "openai_primary": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      },
      "openai_backup": {
        "base_url": "https://api.openai.com",
        "api_key": "env:OPENAI_API_KEY",
        "timeout": "60s"
      }
    }
  }
}
