# -----------------------------
# Server
# -----------------------------
COSTGUARD_PORT=8080
COSTGUARD_ENV=development

# -----------------------------
# Database
# -----------------------------
COSTGUARD_DB_HOST=postgres
COSTGUARD_DB_PORT=5432
COSTGUARD_DB_USER=costguard
COSTGUARD_DB_PASSWORD=costguard
COSTGUARD_DB_NAME=costguard

# -----------------------------
# OpenAI Provider
# -----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------
# Email Alerts (optional)
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=example@gmail.com
SMTP_PASSWORD=your_password
SMTP_FROM=alerts@costguard.ai
ALERT_EMAIL_TO=admin@example.com

# -----------------------------
# Costguard Settings
# -----------------------------
COSTGUARD_CACHE_ENABLED=true
COSTGUARD_CACHE_TTL=300
COSTGUARD_LOG_LEVEL=info

# -----------------------------
# Audio Provider Routing
# -----------------------------
# AUDIO_TRANSCRIPTION_PROVIDER selects the upstream for POST /v1/audio/transcriptions.
# Valid values: openai (default), local
# When set to "local", AUDIO_TRANSCRIPTION_URL is required and must point to an
# OpenAI-compatible STT server (e.g. Speaches, Whisper.cpp, LocalAI).
AUDIO_TRANSCRIPTION_PROVIDER=openai
AUDIO_TRANSCRIPTION_URL=http://speaches:9000
# AUDIO_TRANSCRIPTION_MODEL overrides the model field sent to the local server.
# Use this when your client sends "whisper-1" but the local server expects a
# different model ID (e.g. Systran/faster-whisper-large-v3 for Speaches).
# Leave unset to forward the client-supplied model name unchanged.
AUDIO_TRANSCRIPTION_MODEL=Systran/faster-whisper-large-v3

# AUDIO_TTS_PROVIDER selects the upstream for POST /v1/audio/speech.
# Valid values: openai (default), local
# When set to "local", AUDIO_TTS_URL is required and must point to an
# OpenAI-compatible TTS server (e.g. Kokoro, Piper, LocalAI).
AUDIO_TTS_PROVIDER=openai
AUDIO_TTS_URL=http://kokoro:8880
# AUDIO_TTS_MODEL overrides the model field sent to the local TTS server.
AUDIO_TTS_MODEL=